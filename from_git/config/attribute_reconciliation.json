{
  "schema_version": 1,
  "authority": "NX_TEAMCENTER",
  "save_policy": "NO_SAVE",
  "identity": {
    "part_number": {"category": "Cad0Design", "attribute": "DB_PART_NO", "type": "String"},
    "revision": {"category": "Cad0DesignRevision", "attribute": "DB_PART_REV", "type": "String"}
  },
  "drawing": {
    "relation": "specification",
    "identifier_template": "@DB/{part_number}/{revision}/specification/{part_number}-{revision}-dwg{index}",
    "max_index": 9
  },
  "inputs": {
    "drawing_scope_filename": "NX_DRAWING_SCOPE.csv",
    "master_reference_filename": "NX_ATTRIBUTE_MASTER_REFERENCE.csv",
    "corrections_filename": "NX_ATTRIBUTE_CORRECTIONS.csv"
  },
  "release_policy": {
    "placeholder_values": ["", "TBC", "TBD", "00-JAN-0"],
    "boolean_aliases": {
      "Y": ["Y", "YES", "TRUE", "1"],
      "N": ["N", "NO", "FALSE", "0"]
    },
    "dimension_coordinate_system": "MODEL_ABSOLUTE_XYZ",
    "mass_relative_tolerance": 0.000001
  },
  "bom_export": {
    "columns": [
      "BOM Level",
      "DB_PART_NO",
      "Indented Part Name",
      "Component Name",
      "Quantity",
      "DB_PART_DESC",
      "DB_PART_NAME",
      "DB_PART_REV",
      "MFG",
      "MPN",
      "Stocking_Type"
    ]
  },
  "attributes": [
    {
      "logical_name": "part_number",
      "category": "Cad0Design",
      "attribute": "DB_PART_NO",
      "type": "String",
      "source_owner": "NX_TEAMCENTER_IDENTITY",
      "required_for_certification": true,
      "required_on": ["MODEL", "DRAWING"],
      "comparison": "TRIMMED_CASE_INSENSITIVE",
      "writable": false,
      "write_targets": []
    },
    {
      "logical_name": "revision",
      "category": "Cad0DesignRevision",
      "attribute": "DB_PART_REV",
